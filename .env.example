# Used by src/lib/api.ts. Set at build time (Vite); no trailing slash.
#
# Local dev: omit this or use http://localhost:3000 (same as the default).
# VITE_API_BASE_URL=http://localhost:3000
#
# Production (Netlify): set VITE_API_BASE_URL in the Netlify UI → Site
# configuration → Environment variables → Production (your Railway HTTPS URL).
#
# Local production build test: copy to .env.production.local (gitignored) and run npm run build.
# VITE_API_BASE_URL=https://money-plan-backend-production.up.railway.app
