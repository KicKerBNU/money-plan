{
  "name": "vue-scafold-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 1074",
    "build": "vue-tsc -b && vite build",
    "preview": "concurrently -k -n auth,vite -c cyan,green \"yarn preview:auth\" \"yarn preview:vite\"",
    "preview:auth": "firebase emulators:start --only auth --project money-plan-23efb",
    "preview:vite": "VITE_USE_FIREBASE_AUTH_EMULATOR=true vite build && vite preview --config vite.config.ts --host 0.0.0.0",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "firebase": "^12.12.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/vue3-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.0.9",
    "@types/node": "^24.12.2",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "firebase-tools": "^15.15.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.0.9",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  }
}
